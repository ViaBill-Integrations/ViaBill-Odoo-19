<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="payment_provider_form" model="ir.ui.view">
        <field name="name">payment.provider.form.viabill</field>
        <field name="model">payment.provider</field>
        <field name="inherit_id" ref="payment.payment_provider_form"/>
        <field name="arch" type="xml">

            <!-- ── AUTHENTICATION PANEL (before the credentials group) ── -->
            <group name="provider_credentials" position="before">
                <div
                    name="viabill_auth_panel"
                    invisible="code != 'viabill'"
                    colspan="2"
                >
                    <!-- Login / Register panel (shown when no API key is set) -->
                    <div invisible="viabill_api_key">

                        <div class="alert alert-info mb-3" role="alert">
                            Connect your ViaBill merchant account to automatically retrieve
                            your API Key, Secret Key, and PriceTag Script.
                        </div>

                        <!-- Existing merchant login -->
                        <div class="mb-4">
                            <h6 class="mb-2 fw-bold">Existing User — Log In</h6>
                            <div class="row g-2 mb-2">
                                <div class="col-md-6">
                                    <div class="o_form_label">Email</div>
                                    <input
                                        type="email"
                                        class="form-control form-control-sm"
                                        id="viabill_login_email"
                                        placeholder="merchant@example.com"
                                    />
                                </div>
                                <div class="col-md-6">
                                    <div class="o_form_label">Password</div>
                                    <input
                                        type="password"
                                        class="form-control form-control-sm"
                                        id="viabill_login_password"
                                        placeholder="••••••••"
                                    />
                                </div>
                            </div>
                            <button
                                type="button"
                                class="btn btn-primary btn-sm"
                                id="viabill_btn_login"
                            >
                                Connect with ViaBill
                            </button>
                        </div>

                        <hr/>

                        <!-- New merchant registration -->
                        <div class="mt-3">
                            <h6 class="mb-2 fw-bold">New User — Create Account</h6>
                            <div class="row g-2 mb-2">
                                <div class="col-md-6">
                                    <div class="o_form_label">
                                        Email <span class="text-danger">*</span>
                                    </div>
                                    <input
                                        type="email"
                                        class="form-control form-control-sm"
                                        id="viabill_reg_email"
                                        placeholder="merchant@example.com"
                                    />
                                </div>
                                <div class="col-md-6">
                                    <div class="o_form_label">
                                        Store Name <span class="text-danger">*</span>
                                    </div>
                                    <input
                                        type="text"
                                        class="form-control form-control-sm"
                                        id="viabill_reg_name"
                                        placeholder="My Store"
                                    />
                                </div>
                                <div class="col-md-6">
                                    <div class="o_form_label">
                                        Live Shop URL <span class="text-danger">*</span>
                                    </div>
                                    <input
                                        type="url"
                                        class="form-control form-control-sm"
                                        id="viabill_reg_url"
                                        placeholder="https://mystore.com"
                                    />
                                </div>
                                <div class="col-md-6">
                                    <div class="o_form_label">
                                        Country <span class="text-danger">*</span>
                                    </div>
                                    <input
                                        type="text"
                                        class="form-control form-control-sm"
                                        id="viabill_reg_country"
                                        placeholder="DK"
                                        maxlength="2"
                                    />
                                    <small class="text-muted">2-letter ISO code, e.g. DK, DE, ES</small>
                                </div>
                                <div class="col-md-6">
                                    <div class="o_form_label">Tax ID / VAT</div>
                                    <input
                                        type="text"
                                        class="form-control form-control-sm"
                                        id="viabill_reg_tax_id"
                                        placeholder="Optional"
                                    />
                                </div>
                                <div class="col-md-6">
                                    <div class="o_form_label">Phone</div>
                                    <input
                                        type="tel"
                                        class="form-control form-control-sm"
                                        id="viabill_reg_phone"
                                        placeholder="Optional"
                                    />
                                </div>
                            </div>
                            <button
                                type="button"
                                class="btn btn-success btn-sm"
                                id="viabill_btn_register"
                            >
                                Create ViaBill Account
                            </button>
                        </div>

                        <!-- Status message (shown/hidden by JS) -->
                        <div id="viabill_auth_message" class="mt-3" style="display:none;"/>

                    </div>

                    <!-- Connected banner (shown when API key is already set) -->
                    <div invisible="not viabill_api_key">
                        <div class="alert alert-success mb-0" role="alert">
                            <strong>Connected to ViaBill.</strong>
                            Your API credentials are stored. To reconnect with a different
                            account, clear the API Key field below.
                        </div>
                    </div>

                </div>
            </group>

            <!-- ── CREDENTIALS (inside the existing Credentials tab group) ── -->
            <group name="provider_credentials" position="inside">
                <group invisible="code != 'viabill'" name="viabill_credentials">
                    <field
                        name="viabill_api_key"
                        string="API Key"                        
                    />
                    <field
                        name="viabill_secret_key"
                        string="Secret Key"
                        password="True"                        
                        groups="base.group_system"
                    />
                    <field
                        name="viabill_pricetag_script"
                        string="PriceTag Script"
                        widget="text"
                        placeholder="&lt;script&gt;(function(){{...}})();&lt;/script&gt;"
                    />
                </group>
            </group>

            <!-- ── CONFIGURATION TAB: Transaction type + PriceTags ── -->
            <group name="provider_config" position="inside">

                <!-- Transaction type + order states -->
                <group
                    string="ViaBill Payment Settings"
                    name="viabill_payment_settings"
                    invisible="code != 'viabill'"
                >
                    <field
                        name="viabill_api_mode"
                        string="API Mode"
                        widget="radio"
                    />
                    <field
                        name="viabill_transaction_type"
                        string="Transaction Type"
                        widget="radio"
                    />
                    <field
                        name="viabill_order_state_after_authorize"
                        string="Order State after Authorize"
                        widget="selection"
                    />
                    <field
                        name="viabill_order_state_after_capture"
                        string="Order State after Capture"
                        widget="selection"
                    />
                </group>

                <!-- PriceTags toggles -->
                <group
                    string="ViaBill PriceTags"
                    name="viabill_pricetags_config"
                    invisible="code != 'viabill'"
                >
                    <field
                        name="viabill_pricetag_product"
                        string="Show on Product Page"
                    />
                    <field
                        name="viabill_pricetag_cart"
                        string="Show on Cart Page"
                    />
                    <field
                        name="viabill_pricetag_checkout"
                        string="Show on Checkout Page"
                    />
                    <field
                        name="viabill_pricetag_country"
                        string="PriceTag Country"
                        widget="selection"
                    />
                    <field
                        name="viabill_pricetag_language"
                        string="PriceTag Language"
                        widget="selection"
                    />
                    <field
                        name="viabill_pricetag_product_selector"
                        string="Product Price Selector"
                        placeholder=".oe_price"
                        invisible="not viabill_pricetag_product"
                    />
                    <field
                        name="viabill_pricetag_cart_selector"
                        string="Cart Total Selector"
                        placeholder="strong.monetary_field"
                        invisible="not viabill_pricetag_cart"
                    />
                    <field
                        name="viabill_pricetag_checkout_selector"
                        string="Checkout Total Selector"
                        placeholder="strong.monetary_field"
                        invisible="not viabill_pricetag_checkout"
                    />
                    <field
                        name="viabill_pricetag_custom_css"
                        string="Custom CSS (optional)"
                        widget="text"
                        placeholder=".viabill-pricetag { margin-top: 8px; }"
                    />
                    <field
                        name="viabill_pricetag_custom_js"
                        string="Custom JavaScript (optional)"
                        widget="text"
                        placeholder="// runs after the ViaBill script loads"
                    />
                    <div class="text-muted" colspan="2" invisible="not (viabill_pricetag_product or viabill_pricetag_cart or viabill_pricetag_checkout)">
                        <small>
                            The PriceTag Script (in the Credentials tab) must be set for
                            the widget to appear. It is filled in automatically when you
                            log in or register above.
                        </small>
                    </div>
                </group>

            </group>

        </field>
    </record>

    <!--
        Add a "Troubleshooting" tab to the payment provider form for ViaBill.

        The tab contains:
        - An "Enable Debug" checkbox that activates detailed API logging.
        - A read-only text area showing the last 50 debug log entries.
        - A "Clear Log" button to wipe the log.

        The tab is only visible when the ViaBill provider is selected.        
    -->
    <record id="payment_provider_form_viabill_debug" model="ir.ui.view">
        <field name="name">payment.provider.form.viabill.debug</field>
        <field name="model">payment.provider</field>
        <field name="inherit_id" ref="payment.payment_provider_form"/>
        <field name="priority">20</field>
        <field name="arch" type="xml">
            <notebook position="inside">
                <page
                    string="Troubleshooting"
                    name="viabill_troubleshooting"
                    invisible="code != 'viabill'"
                >
                    <group string="Debug Settings" name="viabill_debug_settings">
                        <field
                            name="viabill_enable_debug"
                            string="Enable Debug"
                        />
                        <div class="text-muted" colspan="2">
                            <small>
                                When enabled, ViaBill API requests and responses are
                                logged below (last 50 entries). Disable in production
                                to avoid storing sensitive data.
                            </small>
                        </div>
                    </group>
                    <group string="Debug Log" name="viabill_debug_log_group">
                        <field
                            name="viabill_debug_log"
                            string=""
                            widget="text"
                            readonly="1"
                            nolabel="1"
                            colspan="2"
                            placeholder="No debug messages yet. Enable Debug above and perform a ViaBill API action."
                        />
                        <div colspan="2" class="mt-2">
                            <button
                                name="action_viabill_clear_debug_log"
                                type="object"
                                string="Clear Log"
                                class="btn btn-sm btn-secondary"
                                confirm="Clear the ViaBill debug log?"
                            />
                        </div>
                    </group>
                </page>
            </notebook>
        </field>
    </record>

</odoo>
