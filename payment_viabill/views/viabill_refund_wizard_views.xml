<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="viabill_refund_wizard_view_form" model="ir.ui.view">
        <field name="name">viabill.refund.wizard.form</field>
        <field name="model">viabill.refund.wizard</field>
        <field name="arch" type="xml">
            <form string="Refund ViaBill Transaction">
                <field name="transaction_id" invisible="1"/>
                <field name="currency_id" invisible="1"/>
                <field name="is_amount_valid" invisible="1"/>

                <group name="readonly_fields">
                    <field name="captured_amount" readonly="1"/>
                    <field name="already_refunded_amount"
                           readonly="1"
                           invisible="already_refunded_amount &lt;= 0"/>
                    <field name="available_amount" readonly="1"/>
                </group>
                <hr/>
                <group name="input_fields">
                    <label for="amount_to_refund" class="oe_inline"/>
                    <field name="amount_to_refund" class="oe_inline"/>
                </group>

                <div role="alert"
                     class="alert alert-warning mb-2"
                     invisible="is_amount_valid">
                    <strong>Warning!</strong> The refund amount must be greater than zero
                    and must not exceed
                    <field name="available_amount" class="oe_inline" widget="monetary"/>.
                </div>

                <footer>
                    <button string="Refund"
                            type="object"
                            name="action_refund"
                            class="btn-primary"
                            invisible="not is_amount_valid"/>
                    <button string="Close" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
